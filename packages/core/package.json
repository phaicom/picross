{
  "name": "@picross/core",
  "type": "module",
  "private": true,
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./src/index.ts",
  "typesVersions": {
    "*": {
      "*": [
        "./src/*",
        "./src/index.ts"
      ]
    }
  },
  "scripts": {
    "build": "unbuild",
    "dev": "unbuild --watch",
    "start": "esno src/index.ts",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@picross/shared": "workspace:*"
  },
  "devDependencies": {
    "esno": "catalog:",
    "typescript": "catalog:",
    "unbuild": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
