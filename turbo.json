{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "**/.env.*local"
  ],
  "globalPassThroughEnv": [
    "COREPACK_HOME"
  ],
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".nuxt/**",
        ".output/**",
        "dist/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "preview": {},
    "generate": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".output/public/**"
      ]
    },
    "test": {},
    "typecheck": {}
  }
}
